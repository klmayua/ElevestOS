# ElevestOS Environment Variables

# Copy this file to .env.local for local development
# Copy this content to Vercel Project Settings for production

# ==========================================
# DATABASE (Required)
# ==========================================
# Use Neon, Supabase, or any PostgreSQL provider
DATABASE_URL="postgresql://username:password@host:5432/elevestos"

# ==========================================
# AUTHENTICATION (Required)
# ==========================================
# Generate a secure secret: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-min-32-characters-long"
JWT_EXPIRES_IN="7d"

# ==========================================
# API (Optional - for external integrations)
# ==========================================
API_KEY="your-api-key-for-external-access"

# ==========================================
# APP CONFIG (Optional)
# ==========================================
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
NODE_ENV="production"

# ==========================================
# EXTERNAL SERVICES (Optional)
# ==========================================
# For email (Resend, SendGrid, etc.)
# EMAIL_API_KEY="your-email-api-key"

# For file storage (AWS S3, etc.)
# S3_BUCKET_NAME="elevestos-files"
# S3_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="your-aws-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret"