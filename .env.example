# Environment variables for development
# Copy this file to .env.local and update with your values

# Database
DATABASE_URL="postgresql://elevestos:elevestos_dev_password@localhost:5432/elevestos?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# NextAuth (if using)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"

# Application
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (for notifications)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@elevestos.com"

# File Storage (S3-compatible)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET="elevestos-dev"

# Feature Flags
NEXT_PUBLIC_FEATURE_GRANTS=true
NEXT_PUBLIC_FEATURE_PROJECTS=true
NEXT_PUBLIC_FEATURE_REPORTING=true
NEXT_PUBLIC_FEATURE_LMS=true
